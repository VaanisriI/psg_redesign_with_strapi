---
import Header from '../components/Header.astro';
import '../styles/global.css';

// Fetch ONLY the 'About PSG-STEP' content using the Strapi Filtering API
let fetchedContent = '';
let pageTitle = 'About PSG-STEP';
let imageUrl = '';

try {
  // Utilizing Strapi's filtering system to only request the specific "About PSG-STEP" record
  const res = await fetch('http://127.0.0.1:1337/api/abouts?filters[title][$eq]=About PSG-STEP&populate=*');
  if (res.ok) {
    const json = await res.json();
    if (json.data && json.data.length > 0) {
      const doc = json.data[0];
      pageTitle = doc.title || 'About PSG-STEP';
      fetchedContent = doc.content || '';
      
      // Cleanup Strapi legacy rich text formats and inject modern tailwind classes, using the brand red accent (#cc1818)
      fetchedContent = fetchedContent.replace(/<font color="#0000CD">\s*<b>(.*?)<\/b>\s*<\/font>/gi, '<span class="text-[#8B1A1A] font-black bg-red-500/10 px-2 py-0.5 rounded-lg border border-red-500/20 shadow-sm transition-all duration-300 hover:bg-red-500/20 mb-1 leading-relaxed inline-block">$1</span>');
      fetchedContent = fetchedContent.replace(/<b>\s*<font color="#0000CD">(.*?)<\/font>\s*<\/b>/gi, '<span class="text-[#8B1A1A] font-black bg-red-500/10 px-2 py-0.5 rounded-lg border border-red-500/20 shadow-sm transition-all duration-300 hover:bg-red-500/20 mb-1 leading-relaxed inline-block">$1</span>');
      fetchedContent = fetchedContent.replace(/<font color="#0000CD">(.*?)<\/font>/gi, '<span class="text-red-700 font-bold">$1</span>');

      // Check if image exists in relation data
      if (doc.image && doc.image.url) {
        imageUrl = `http://127.0.0.1:1337${doc.image.url}`;
      } else if (doc.Images && doc.Images.length > 0) {
        imageUrl = `http://127.0.0.1:1337${doc.Images[0].url}`;
      } else if (doc.Image && doc.Image.url) {
         imageUrl = `http://127.0.0.1:1337${doc.Image.url}`;
      }
    }
  }
} catch (error) {
  console.error(`Error fetching ${pageTitle}:`, error);
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>PSG-STEP | {pageTitle}</title>
    <!-- High-end structural font for a highly professional aesthetic -->
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-slate-50 text-slate-800 font-['Outfit'] min-h-screen flex flex-col antialiased selection:bg-red-200 selection:text-red-900 overflow-x-hidden">
    <Header />
    
    <!-- Immersive Hero Section -->
    <div class="relative w-full pt-32 pb-24 md:pt-44 md:pb-32 overflow-hidden bg-[#1E0F14]">
      <!-- Animated Background Effects using Brand Colors (Deep Red & Violet) -->
      <div class="absolute inset-0 overflow-hidden pointer-events-none">
        <div class="absolute -top-[40%] -right-[20%] w-[80%] h-[80%] rounded-full bg-gradient-to-b from-red-600/20 to-purple-800/30 blur-[130px] mix-blend-screen animate-pulse duration-[8000ms]"></div>
        <div class="absolute -bottom-[20%] -left-[10%] w-[60%] h-[60%] rounded-full bg-gradient-to-t from-orange-500/20 to-red-600/10 blur-[100px] mix-blend-screen opacity-70"></div>
        <!-- Subtle Pattern Overlay -->
        <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] opacity-[0.03]"></div>
      </div>
      
      <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-12">
        <div class="flex flex-col items-center text-center">
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/5 border border-white/10 backdrop-blur-md mb-8 transform hover:scale-105 transition-all duration-300 hover:bg-white/10 cursor-default">
            <span class="w-2 h-2 rounded-full bg-red-400 animate-[ping_2s_cubic-bezier(0,0,0.2,1)_infinite]"></span>
            <span class="text-red-300 font-bold text-xs tracking-[0.25em] uppercase">Programme Overview</span>
          </div>
          
          <h1 class="text-5xl md:text-6xl lg:text-7xl font-black text-transparent bg-clip-text bg-gradient-to-r from-white via-red-50 to-white mb-6 tracking-tight leading-[1.1] drop-shadow-2xl">
            {pageTitle}
          </h1>
          
          <div class="w-24 h-1.5 bg-gradient-to-r from-red-500 to-orange-400 rounded-full mb-8 shadow-[0_0_15px_rgba(239,68,68,0.5)]"></div>
          
          <p class="text-slate-300 max-w-2xl text-lg md:text-xl font-light leading-relaxed">
            Fostering innovation, accelerating startups, and shaping the future of technology entrepreneurship.
          </p>
        </div>
      </div>
      
      <!-- Wave transition -->
      <div class="absolute bottom-0 left-0 right-0 w-full overflow-hidden leading-none z-20">
        <svg class="relative block w-full h-[60px] md:h-[100px]" data-name="Layer 1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 120" preserveAspectRatio="none">
            <path d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V120H0V95.8C59.71,118.08,130.83,119.78,189.22,109.28Z" class="fill-slate-50"></path>
        </svg>
      </div>
    </div>

    <!-- Main Content Area -->
    <main class="flex-1 relative z-30 pb-28 -mt-2">
      <div class="max-w-5xl mx-auto px-6 lg:px-12">
        <div class="bg-white rounded-3xl shadow-[0_20px_50px_rgba(0,0,0,0.06)] border border-slate-100/60 p-8 md:p-14 lg:p-16 relative overflow-hidden backdrop-blur-xl group hover:shadow-[0_20px_50px_rgba(0,0,0,0.1)] transition-all duration-500">
          
          <!-- Decorative UI Elements Inside Card -->
          <div class="absolute top-0 left-0 w-64 h-64 bg-gradient-to-br from-red-50 to-orange-50 rounded-full blur-3xl -z-10 opacity-60 group-hover:opacity-100 transition-opacity duration-700"></div>
          <div class="absolute -bottom-20 -right-20 w-80 h-80 bg-gradient-to-tr from-rose-50 to-red-50 rounded-full blur-3xl -z-10 opacity-50"></div>
          
          <div class="relative z-10">
            
            <div class="flex flex-col lg:flex-row gap-12 items-start">
              <!-- Dynamic Fetched Content Area -->
              <div class={`prose prose-lg max-w-none prose-p:text-slate-600 prose-p:leading-[1.85] prose-p:mb-8 prose-p:text-justify prose-p:font-medium prose-p:text-[1.05rem] md:prose-p:text-[1.125rem] prose-headings:font-black prose-headings:text-slate-800 prose-strong:text-[#cc1818] prose-a:text-[#cc1818] prose-a:no-underline hover:prose-a:underline ${imageUrl ? 'lg:w-3/5' : 'w-full'}`}>
                {fetchedContent ? (
                  <div class="animate-[fadeIn_0.6s_ease-out_forwards]">
                    <Fragment set:html={fetchedContent} />
                  </div>
                ) : (
                  <div class="flex flex-col items-center justify-center py-16 text-slate-400 space-y-5">
                    <div class="relative w-12 h-12">
                      <div class="absolute inset-0 border-4 border-red-100 rounded-full"></div>
                      <div class="absolute inset-0 border-4 border-[#cc1818] rounded-full border-t-transparent animate-spin"></div>
                    </div>
                    <p class="font-medium text-lg animate-pulse text-slate-500">Fetching programme details...</p>
                  </div>
                )}
              </div>
              
              {imageUrl && (
                <div class="w-full lg:w-2/5 lg:sticky lg:top-32 animate-[fadeIn_0.8s_ease-out_forwards]">
                  <div class="relative rounded-[2rem] overflow-hidden shadow-2xl group">
                    <div class="absolute inset-0 bg-red-500/10 group-hover:bg-transparent transition-colors duration-500 z-10 pointer-events-none"></div>
                    <img src={imageUrl} alt={pageTitle} class="w-full h-auto object-cover transform group-hover:scale-105 transition-transform duration-700" />
                  </div>
                </div>
              )}
            </div>
            
            <!-- Contextual Footer within card -->
            {fetchedContent && (
               <div class="mt-12 pt-8 border-t border-slate-100 flex flex-col sm:flex-row items-center justify-between text-sm text-slate-500 font-medium animate-[fadeIn_0.8s_ease-out_forwards]">
                 <div class="flex items-center gap-2 mb-4 sm:mb-0">
                   <svg class="w-5 h-5 text-[#cc1818]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
                   <span>Information provided by PSG-STEP Management</span>
                 </div>
                 <div class="bg-red-50 text-[#cc1818] px-3 py-1 rounded-full text-xs font-bold tracking-wider">
                   OFFICIAL
                 </div>
               </div>
            )}
          </div>
        </div>
      </div>
    </main>
    
    <style>
      @keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
      }
    </style>
  </body>
</html>
