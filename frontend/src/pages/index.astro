                   </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Sleek Floating Controls -->
        <button id="slider-prev" aria-label="Previous slide" class="absolute left-4 lg:left-8 top-1/2 -translate-y-1/2 z-30 w-14 h-14 rounded-full bg-white/5 hover:bg-white/20 border border-white/10 text-white backdrop-blur-md flex items-center justify-center transition-all opacity-0 group-hover:opacity-100 hover:scale-110 shadow-xl cursor-pointer">
          <svg class="w-7 h-7 ml-[-2px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
        </button>
        <button id="slider-next" aria-label="Next slide" class="absolute right-4 lg:right-8 top-1/2 -translate-y-1/2 z-30 w-14 h-14 rounded-full bg-white/5 hover:bg-white/20 border border-white/10 text-white backdrop-blur-md flex items-center justify-center transition-all opacity-0 group-hover:opacity-100 hover:scale-110 shadow-xl cursor-pointer">
          <svg class="w-7 h-7 mr-[-2px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </button>

        <!-- Dynamic Dots -->
        <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-30 flex gap-3 bg-white/5 backdrop-blur-md px-5 py-2.5 rounded-full border border-white/10">
          <button class="slider-dot w-8 h-2 rounded-full bg-blue-500 shadow-[0_0_15px_rgba(59,130,246,0.5)] transition-all duration-300 cursor-pointer" data-dot="0"></button>
          <button class="slider-dot w-2 h-2 rounded-full bg-white/40 hover:bg-white shadow-[0_0_15px_rgba(255,255,255,0.2)] transition-all duration-300 cursor-pointer" data-dot="1"></button>
        </div>
      </div>

      <!-- ░░ 3. Catchy About Us & Video Section ░░ -->
      <div class="relative max-w-[1400px] mx-auto px-6 lg:px-12 py-24 z-40">
         <div class="grid lg:grid-cols-2 gap-16 items-center">
            
            <!-- Highly Styled Video Frame -->
            <div class="relative group">
               <!-- Decorative Blurs for Premium Feel -->
               <div class="absolute -top-10 -left-10 w-72 h-72 bg-blue-500/10 rounded-full blur-3xl opacity-70 group-hover:bg-blue-500/20 transition-colors duration-700"></div>
