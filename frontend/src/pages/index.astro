               </div>
               
               <!-- Floating Play badge -->
               <div class="absolute -bottom-6 -right-6 bg-white p-5 rounded-3xl shadow-xl shadow-slate-200 border border-slate-50 z-20 hidden md:flex items-center gap-4 hover:-translate-y-1 transition-transform cursor-pointer">
