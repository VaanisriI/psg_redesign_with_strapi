---
import Header from '../components/Header.astro';
import '../styles/global.css';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>PSG-STEP | Home</title>
    <!-- High-end structural font for a highly professional aesthetic -->
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
  </head>

  <body class="bg-[#f8fafc] text-slate-800 font-['Outfit'] min-h-screen flex flex-col antialiased selection:bg-blue-200">
    <Header />

    <main class="flex-1">

      <!-- ░░ 1. Institutional Motivation Quote (Sleek Minimalist) ░░ -->
      <div class="bg-white border-b border-slate-100 shadow-sm relative z-20">
        <div class="max-w-4xl mx-auto px-6 py-8 md:py-10 text-center relative">
          <svg class="w-10 h-10 text-blue-100 absolute top-4 left-1/2 -translate-x-1/2 -z-10" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
          <h2 class="text-xl md:text-2xl lg:text-3xl italic font-medium leading-relaxed tracking-tight text-slate-800">
            "Let there be charity, so that others can share my family's prosperity"
          </h2>
          <div class="mt-5 flex items-center justify-center gap-4">
            <span class="w-12 h-px bg-slate-300"></span>
            <p class="text-xs md:text-sm text-blue-600 font-bold tracking-[0.2em] uppercase">
              PS Govindasamy Naidu
            </p>
            <span class="w-12 h-px bg-slate-300"></span>
          </div>
        </div>
      </div>

      <!-- ░░ 2. Premium CSS-Driven Hero Slider ░░ -->
      <div class="relative w-full h-[500px] lg:h-[650px] bg-slate-900 group shadow-2xl shadow-slate-900/10 overflow-hidden" id="hero-slider">
        
        <!-- Slide 1 (Deep Blue Radial + Dots) -->
        <div class="slider-slide absolute inset-0 transition-opacity duration-1000 opacity-100 ease-in-out" data-slide="0">
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,_var(--tw-gradient-stops))] from-blue-800 via-[#0f2147] to-slate-900"></div>
          <div class="absolute inset-0 opacity-[0.07]" style="background-image: radial-gradient(#ffffff 2px, transparent 2px); background-size: 32px 32px;"></div>
          
          <div class="absolute inset-0 flex items-center">
            <div class="max-w-[1400px] mx-auto px-6 lg:px-12 w-full mt-10">
              <div class="max-w-4xl border-l-[8px] border-blue-500 pl-8 md:pl-12 py-4">
                <div class="inline-block px-4 py-1.5 bg-blue-500/20 border border-blue-400/30 text-blue-200 font-bold text-xs uppercase tracking-[0.2em] rounded-full mb-6 backdrop-blur-md">
                   Incubation Program
                </div>
                <h1 class="text-4xl md:text-6xl lg:text-[5rem] font-black text-white leading-[1.1] tracking-tight drop-shadow-2xl mb-6">
                  Transform your idea <br class="hidden md:block" />to a working <span class="bg-gradient-to-r from-blue-400 to-indigo-300 bg-clip-text text-transparent">prototype.</span>
                </h1>
                <p class="text-xl md:text-2xl text-slate-300 font-medium tracking-wide">
                  Empowered by <span class="text-white font-bold tracking-wider">MeitY TIDE 2.0</span>
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- Slide 2 (Indigo Mesh + Grid) -->
        <div class="slider-slide absolute inset-0 transition-opacity duration-1000 opacity-0 ease-in-out" data-slide="1">
          <div class="absolute inset-0 bg-gradient-to-br from-[#1a2b6e] via-[#0b1633] to-[#040914]"></div>
          <div class="absolute -top-[20%] -right-[10%] w-[60%] h-[60%] rounded-full bg-blue-600/20 blur-[120px]"></div>
          <div class="absolute -bottom-[20%] -left-[10%] w-[60%] h-[60%] rounded-full bg-indigo-600/20 blur-[120px]"></div>
          <div class="absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(rgba(255,255,255,1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,1) 1px, transparent 1px); background-size: 40px 40px;"></div>
          
          <div class="absolute inset-0 flex items-center justify-center text-center">
            <div class="max-w-[1400px] mx-auto px-6 lg:px-12 w-full mt-10">
              <div class="max-w-3xl mx-auto">
                <div class="inline-block px-5 py-2 bg-amber-500/10 border border-amber-500/30 text-amber-300 font-bold text-xs uppercase tracking-[0.25em] rounded-full mb-8 backdrop-blur-md shadow-[0_0_20px_rgba(245,158,11,0.2)]">
                   Applications Open
                </div>
                <h1 class="text-4xl md:text-5xl lg:text-7xl font-black text-white leading-tight tracking-tight drop-shadow-2xl mb-12">
                  Apply for MeitY TIDE 2.0
                </h1>
                
                <div class="flex flex-col sm:flex-row justify-center gap-6">
                   <div class="bg-white/5 backdrop-blur-xl border border-white/10 p-6 rounded-3xl flex items-center gap-5 shadow-2xl hover:-translate-y-1 transition-transform">
                      <div class="w-14 h-14 rounded-2xl bg-blue-500/20 border border-blue-500/30 text-blue-400 flex items-center justify-center">
