                  <div>
                     <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-0.5">Campus Tour</p>
                     <p class="text-lg font-black text-[#1a2b6e]">Inside PSG-STEP</p>
                  </div>
               </div>
            </div>
            
            <!-- Beautifully Typographed Content Box -->
            <div class="max-w-xl">
               <div class="inline-block px-4 py-1.5 bg-blue-50 border border-blue-100 text-blue-600 font-bold text-xs uppercase tracking-[0.2em] rounded-full mb-6 relative hover:scale-105 transition-transform">
                  <span class="absolute top-1/2 left-0 w-2 h-2 bg-blue-500 rounded-full -translate-x-1 -translate-y-1/2 animate-pulse"></span>
                  About Us
