---
import ProgramLayout from '../../components/ProgramLayout.astro';
import { getProgramBySlug } from '../../lib/strapi';

const slug = Astro.url.pathname.split('/').filter(Boolean).pop();
const program = await getProgramBySlug(slug);

const accent = {
  grad: 'linear-gradient(135deg,#0f766e 0%,#2563eb 100%)',
  gradFrom: 'from-teal-700',
  gradTo: 'to-blue-600',
};

const heroImage = 'https://images.unsplash.com/photo-1518770660439-4636190af475?q=80&w=2400&auto=format&fit=crop';
---
<ProgramLayout program={program} accent={accent} heroImage={heroImage} />
