---
import ProgramLayout from '../../components/ProgramLayout.astro';

const res = await fetch('http://127.0.0.1:1337/api/programs/pl69hm281qeyqr3shpqw5u5i?populate=image');
const json = await res.json();
const program = json.data;

const accent = {
  grad: 'linear-gradient(135deg,#be185d 0%,#7c3aed 100%)',
  gradFrom: 'from-pink-700',
  gradTo: 'to-purple-700',
};

const heroImage = 'https://images.unsplash.com/photo-1579684385127-1ef15d508118?q=80&w=2400&auto=format&fit=crop';
---
<ProgramLayout program={program} accent={accent} heroImage={heroImage} />
