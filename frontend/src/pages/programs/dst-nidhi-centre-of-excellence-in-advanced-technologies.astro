---
import ProgramLayout from '../../components/ProgramLayout.astro';

let program = null;
try {
  const res = await fetch('http://localhost:1337/api/programs/uvbmzud3fnsmi44acphacmax?populate=image');
  if (res.ok) {
    const json = await res.json();
    program = json.data;
  } else {
    console.error(`Failed to fetch program: ${res.status} ${res.statusText}`);
  }
} catch (error) {
  console.error("Fetch error:", error);
}

const accent = {
  grad: 'linear-gradient(135deg,#1a2b6e 0%,#cc1818 100%)',
  gradFrom: 'from-[#1a2b6e]',
  gradTo: 'to-[#cc1818]',
};

const heroImage = 'https://images.unsplash.com/photo-1485827404703-89b55fcc595e?q=80&w=2400&auto=format&fit=crop';
---
<ProgramLayout program={program} accent={accent} heroImage={heroImage} />
