---
import ProgramLayout from '../../components/ProgramLayout.astro';

const res = await fetch('http://127.0.0.1:1337/api/programs/z6rhha8bdculosyjw3tgzj9h?populate=image');
const json = await res.json();
const program = json.data;

const accent = {
  grad: 'linear-gradient(135deg,#047857 0%,#0369a1 100%)',
  gradFrom: 'from-emerald-700',
  gradTo: 'to-sky-700',
};

const heroImage = 'https://images.unsplash.com/photo-1532094349884-543bc11b234d?q=80&w=2400&auto=format&fit=crop';
---
<ProgramLayout program={program} accent={accent} heroImage={heroImage} />
