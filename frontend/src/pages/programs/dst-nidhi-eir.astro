---
import ProgramLayout from '../../components/ProgramLayout.astro';

const res = await fetch('http://127.0.0.1:1337/api/programs/pm2u7q0l5tpook6ffimbmotd?populate=image');
const json = await res.json();
const program = json.data;

const accent = {
  grad: 'linear-gradient(135deg,#0369a1 0%,#0891b2 100%)',
  gradFrom: 'from-sky-700',
  gradTo: 'to-cyan-600',
};

const heroImage = 'https://images.unsplash.com/photo-1519389950473-47ba0277781c?q=80&w=2400&auto=format&fit=crop';
---
<ProgramLayout program={program} accent={accent} heroImage={heroImage} />
