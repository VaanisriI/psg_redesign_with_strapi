---
import ProgramLayout from '../../components/ProgramLayout.astro';

const res = await fetch('http://127.0.0.1:1337/api/programs/rdtr1r6tei931bx9wq09na3x?populate=image');
const json = await res.json();
const program = json.data;

const accent = {
  grad: 'linear-gradient(135deg,#b45309 0%,#c2410c 100%)',
  gradFrom: 'from-amber-700',
  gradTo: 'to-orange-700',
};

const heroImage = 'https://images.unsplash.com/photo-1487452066049-a710f7296400?q=80&w=2400&auto=format&fit=crop';
---
<ProgramLayout program={program} accent={accent} heroImage={heroImage} />
