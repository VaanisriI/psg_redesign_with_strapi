---
// Header.astro
---

<!-- ░░ Top Marquee Bar ░░ -->
<div class="bg-[#1a2b6e] overflow-hidden border-b border-white/10">
  <div class="py-2 px-4 text-[12.5px]">
    <div class="marquee-track whitespace-nowrap inline-flex items-center gap-14 font-semibold tracking-wide text-blue-100">
      <span class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-blue-300 animate-pulse inline-block"></span>Welcome to PSG Science &amp; Technology Entrepreneurs Programme</span>
      <span class="text-white/30">|</span>
      <span class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse inline-block"></span>Apply for NIDHI PRAYAS 2024</span>
      <span class="text-white/30">|</span>
      <span class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-amber-400 animate-pulse inline-block"></span>TIDE 2.0 Applications Open</span>
      <span class="text-white/30">|</span>
      <span class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-blue-300 animate-pulse inline-block"></span>Welcome to PSG Science &amp; Technology Entrepreneurs Programme</span>
      <span class="text-white/30">|</span>
      <span class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse inline-block"></span>Apply for NIDHI PRAYAS 2024</span>
      <span class="text-white/30">|</span>
      <span class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-amber-400 animate-pulse inline-block"></span>TIDE 2.0 Applications Open</span>
    </div>
  </div>
</div>

<!-- ░░ Two-Bar Sticky Header ░░ -->
<div class="sticky top-0 z-50">

  <!-- ── Bar 1: Logo ── -->
  <div class="bg-white border-b border-gray-100 shadow-sm">
    <div class="max-w-7xl mx-auto px-4 lg:px-8 py-3 flex items-center justify-between">
      <a href="/" class="group flex-1 min-w-0">
        <img
          src="/images/logo.jpg"
          alt="PSG-STEP Logo"
          class="w-full h-auto max-h-16 object-contain object-left group-hover:opacity-90 transition-opacity duration-200"
        />
      </a>
      <!-- Mobile Hamburger (visible on mobile only) -->
      <button id="mobile-toggle" class="lg:hidden flex items-center justify-center w-10 h-10 rounded-lg text-[#1a2b6e] hover:bg-blue-50 transition-colors" aria-label="Open menu">
        <svg id="hamburger-icon" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/>
        </svg>
        <svg id="close-icon" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- ── Bar 2: Navigation ── -->
  <div class="bg-[#1a2b6e] border-b border-white/10 hidden lg:block">
    <div class="max-w-7xl mx-auto px-4 lg:px-8">
      <nav class="flex items-center h-12 text-[13px] font-bold" id="desktop-nav">

        <!-- Main nav items — centered -->
        <div class="flex-1 flex items-center justify-center h-full">

        <!-- Home -->
        <a href="/" class="nav-link px-4 h-full flex items-center text-white/85 hover:text-white transition-colors relative">
          Home
          <span class="nav-underline absolute bottom-0 left-0 w-full h-[3px] bg-[#cc1818] rounded-t scale-x-0 transition-transform origin-center duration-200"></span>
        </a>

        <!-- About -->
        <div class="relative h-full flex items-center" data-dropdown="about">
          <button data-trigger class="nav-link px-4 h-full flex items-center gap-1.5 text-white/85 hover:text-white transition-colors relative">
            About
            <svg data-chevron class="w-3.5 h-3.5 text-white/40 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            <span class="nav-underline absolute bottom-0 left-0 w-full h-[3px] bg-[#cc1818] rounded-t scale-x-0 transition-transform origin-center duration-200"></span>
          </button>
          <div data-panel class="dropdown-panel absolute top-full left-0 w-60 pt-1 opacity-0 invisible translate-y-1 transition-all duration-200 pointer-events-none">
            <div class="bg-white border border-slate-100 shadow-2xl shadow-slate-200/60 rounded-xl py-2">
              <a href="/about-psg-tech" class="dd-item flex items-center justify-between px-5 py-2.5 text-slate-600 hover:bg-slate-50 hover:text-[#1a2b6e] transition-colors">
                About PSG Tech <span class="arrow text-[#1a2b6e] opacity-0 -translate-x-1 transition-all font-bold text-base leading-none">›</span>
              </a>
              <div class="relative" data-dropdown="about-step">
                <button data-trigger class="dd-item w-full flex items-center justify-between px-5 py-2.5 text-slate-600 hover:bg-slate-50 hover:text-[#1a2b6e] transition-colors">
                  About PSG-STEP
                  <svg data-chevron class="w-3.5 h-3.5 text-slate-300 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                </button>
                <div data-panel class="dropdown-panel absolute top-0 left-full ml-1 w-60 opacity-0 invisible translate-x-[-4px] transition-all duration-200 pointer-events-none">
                  <div class="bg-white border border-slate-100 shadow-2xl shadow-slate-200/60 rounded-xl py-2">
                    <a href="/about-psg-step" class="dd-item block px-5 py-2.5 text-slate-600 hover:bg-slate-50 hover:text-[#1a2b6e] transition-colors">Overview</a>
                    <a href="#" class="dd-item block px-5 py-2.5 text-slate-600 hover:bg-slate-50 hover:text-[#1a2b6e] transition-colors">Vision</a>
                    <a href="#" class="dd-item block px-5 py-2.5 text-slate-600 hover:bg-slate-50 hover:text-[#1a2b6e] transition-colors">Mission</a>
                    <a href="#" class="dd-item block px-5 py-2.5 text-slate-600 hover:bg-slate-50 hover:text-[#1a2b6e] transition-colors">Team PSG-STEP</a>
                    <a href="#" class="dd-item block px-5 py-2.5 text-slate-600 hover:bg-slate-50 hover:text-[#1a2b6e] transition-colors leading-snug">
                      Video of Incubation<br><span class="text-xs text-slate-400 font-medium">Facilities @ PSG-STEP</span>
                    </a>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Incubation Facility -->
        <div class="relative h-full flex items-center" data-dropdown="facility">
          <button data-trigger class="nav-link px-4 h-full flex items-center gap-1.5 text-white/85 hover:text-white transition-colors relative">
            Incubation Facility
            <svg data-chevron class="w-3.5 h-3.5 text-white/40 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            <span class="nav-underline absolute bottom-0 left-0 w-full h-[3px] bg-[#cc1818] rounded-t scale-x-0 transition-transform origin-center duration-200"></span>
          </button>
          <div data-panel class="dropdown-panel absolute top-full left-0 w-[320px] pt-1 opacity-0 invisible translate-y-1 transition-all duration-200 pointer-events-none">
            <div class="bg-white border border-slate-100 shadow-2xl shadow-slate-200/60 rounded-xl py-2">
              <a href="#" class="dd-item block px-5 py-2.5 text-slate-600 hover:bg-slate-50 hover:text-[#1a2b6e] transition-colors">ICT</a>
              <a href="#" class="dd-item block px-5 py-2.5 text-slate-600 hover:bg-slate-50 hover:text-[#1a2b6e] transition-colors">Electronics</a>
              <a href="#" class="dd-item block px-5 py-2.5 text-slate-600 hover:bg-slate-50 hover:text-[#1a2b6e] transition-colors">BIRAC BioNEST Bioincubation Centre</a>
              <a href="#" class="dd-item block px-5 py-2.5 text-slate-600 hover:bg-slate-50 hover:text-[#1a2b6e] transition-colors leading-snug">
                DST Nanotechnology – Research<br><span class="text-xs text-slate-400 font-medium">Innovation and Incubation Centre</span>
              </a>
              <a href="#" class="dd-item block px-5 py-2.5 text-slate-600 hover:bg-slate-50 hover:text-[#1a2b6e] transition-colors">Mechanical</a>
              <a href="#" class="dd-item block px-5 py-2.5 text-slate-600 hover:bg-slate-50 hover:text-[#1a2b6e] transition-colors leading-snug">
                DST NIDHI-Centre of Excellence<br><span class="text-xs text-slate-400 font-medium">in Advanced Technologies</span>
              </a>
            </div>
          </div>
        </div>

        <!-- Programs -->
        <div class="relative h-full flex items-center" data-dropdown="programs">
          <button data-trigger class="nav-link px-4 h-full flex items-center gap-1.5 text-white/85 hover:text-white transition-colors relative">
            Programs
            <svg data-chevron class="w-3.5 h-3.5 text-white/40 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            <span class="nav-underline absolute bottom-0 left-0 w-full h-[3px] bg-[#cc1818] rounded-t scale-x-0 transition-transform origin-center duration-200"></span>
          </button>
          <div data-panel class="dropdown-panel absolute top-full left-0 w-[300px] pt-1 opacity-0 invisible translate-y-1 transition-all duration-200 pointer-events-none">
            <div class="bg-white border border-slate-100 shadow-2xl shadow-slate-200/60 rounded-xl py-2">
              <a href="/programs/dst-nidhi-centre-of-excellence-in-advanced-technologies" class="dd-item flex items-center justify-between px-5 py-2.5 text-slate-600 hover:bg-slate-50 hover:text-[#1a2b6e] transition-colors">
                DST-NIDHI Centre of Excellence <span class="arrow text-[#1a2b6e] opacity-0 -translate-x-1 transition-all font-bold text-base">›</span>
              </a>
              <a href="/programs/dst-nidhi-prayas" class="dd-item flex items-center justify-between px-5 py-2.5 text-slate-600 hover:bg-slate-50 hover:text-[#1a2b6e] transition-colors">
                DST NIDHI – PRAYAS <span class="arrow text-[#1a2b6e] opacity-0 -translate-x-1 transition-all font-bold text-base">›</span>
              </a>
              <a href="/programs/dst-nidhi-eir" class="dd-item flex items-center justify-between px-5 py-2.5 text-slate-600 hover:bg-slate-50 hover:text-[#1a2b6e] transition-colors">
                DST NIDHI – EIR <span class="arrow text-[#1a2b6e] opacity-0 -translate-x-1 transition-all font-bold text-base">›</span>
              </a>
              <a href="/programs/meity-tide-2-0" class="dd-item flex items-center justify-between px-5 py-2.5 text-slate-600 hover:bg-slate-50 hover:text-[#1a2b6e] transition-colors">
                MeitY TIDE 2.0 <span class="arrow text-[#1a2b6e] opacity-0 -translate-x-1 transition-all font-bold text-base">›</span>
              </a>
              <a href="/programs/birac-sparsh" class="dd-item flex items-center justify-between px-5 py-2.5 text-slate-600 hover:bg-slate-50 hover:text-[#1a2b6e] transition-colors">
                BIRAC – SPARSH <span class="arrow text-[#1a2b6e] opacity-0 -translate-x-1 transition-all font-bold text-base">›</span>
              </a>
              <a href="/programs/birac-bionest-initiatives" class="dd-item flex items-center justify-between px-5 py-2.5 text-slate-600 hover:bg-slate-50 hover:text-[#1a2b6e] transition-colors">
                BIRAC BioNEST Initiatives <span class="arrow text-[#1a2b6e] opacity-0 -translate-x-1 transition-all font-bold text-base">›</span>
              </a>
              <a href="/programs/idex-partner-incubator" class="dd-item flex items-center justify-between px-5 py-2.5 text-slate-600 hover:bg-slate-50 hover:text-[#1a2b6e] transition-colors">
                iDEX Partner Incubator <span class="arrow text-[#1a2b6e] opacity-0 -translate-x-1 transition-all font-bold text-base">›</span>
              </a>
              <a href="/programs/startuptn-initiatives" class="dd-item flex items-center justify-between px-5 py-2.5 text-slate-600 hover:bg-slate-50 hover:text-[#1a2b6e] transition-colors">
                StartupTN Initiatives <span class="arrow text-[#1a2b6e] opacity-0 -translate-x-1 transition-all font-bold text-base">›</span>
              </a>
            </div>
          </div>
        </div>

        <!-- Startups -->
        <div class="relative h-full flex items-center" data-dropdown="startups">
          <button data-trigger class="nav-link px-4 h-full flex items-center gap-1.5 text-white/85 hover:text-white transition-colors relative">
            Startups
            <svg data-chevron class="w-3.5 h-3.5 text-white/40 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            <span class="nav-underline absolute bottom-0 left-0 w-full h-[3px] bg-[#cc1818] rounded-t scale-x-0 transition-transform origin-center duration-200"></span>
          </button>
          <div data-panel class="dropdown-panel absolute top-full left-0 w-56 pt-1 opacity-0 invisible translate-y-1 transition-all duration-200 pointer-events-none">
            <div class="bg-white border border-slate-100 shadow-2xl shadow-slate-200/60 rounded-xl py-2">
              <div class="relative" data-dropdown="incubatee">
                <button data-trigger class="dd-item w-full flex items-center justify-between px-5 py-2.5 text-slate-600 hover:bg-slate-50 hover:text-[#1a2b6e] transition-colors">
                  Incubatee Profile
                  <svg data-chevron class="w-3.5 h-3.5 text-slate-300 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                </button>
                <div data-panel class="dropdown-panel absolute top-0 left-full ml-1 w-56 opacity-0 invisible translate-x-[-4px] transition-all duration-200 pointer-events-none">
                  <div class="bg-white border border-slate-100 shadow-2xl shadow-slate-200/60 rounded-xl py-2">
                    <a href="#" class="dd-item block px-5 py-2.5 text-slate-600 hover:bg-slate-50 hover:text-[#1a2b6e] transition-colors">Present Incubatees</a>
                    <a href="#" class="dd-item block px-5 py-2.5 text-slate-600 hover:bg-slate-50 hover:text-[#1a2b6e] transition-colors">Graduated Incubatees</a>
                  </div>
                </div>
              </div>
              <div class="relative" data-dropdown="funding">
                <button data-trigger class="dd-item w-full flex items-center justify-between px-5 py-2.5 text-slate-600 hover:bg-slate-50 hover:text-[#1a2b6e] transition-colors">
                  Funding
                  <svg data-chevron class="w-3.5 h-3.5 text-slate-300 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                </button>
                <div data-panel class="dropdown-panel absolute top-0 left-full ml-1 w-80 opacity-0 invisible translate-x-[-4px] transition-all duration-200 pointer-events-none">
                  <div class="bg-white border border-slate-100 shadow-2xl shadow-slate-200/60 rounded-xl py-2">
                    <a href="#" class="dd-item block px-5 py-2.5 text-slate-600 hover:bg-slate-50 hover:text-[#1a2b6e] transition-colors">Seed Fund Support Scheme</a>
                    <a href="#" class="dd-item block px-5 py-2.5 text-slate-600 hover:bg-slate-50 hover:text-[#1a2b6e] transition-colors">Seed Fund Support Scheme – TDB / NSTEDB</a>
                    <a href="#" class="dd-item block px-5 py-2.5 text-slate-600 hover:bg-slate-50 hover:text-[#1a2b6e] transition-colors">MSME Incubator Scheme</a>
                    <a href="#" class="dd-item block px-5 py-2.5 text-slate-600 hover:bg-slate-50 hover:text-[#1a2b6e] transition-colors">EDII – Innovation Voucher Program (IVP)</a>
                    <a href="#" class="dd-item block px-5 py-2.5 text-slate-600 hover:bg-slate-50 hover:text-[#1a2b6e] transition-colors">DST NIDHI – PRAYAS</a>
                    <a href="#" class="dd-item block px-5 py-2.5 text-slate-600 hover:bg-slate-50 hover:text-[#1a2b6e] transition-colors">MeitY TIDE 2.0</a>
                  </div>
                </div>
              </div>
              <a href="#" class="dd-item flex items-center justify-between px-5 py-2.5 text-slate-600 hover:bg-slate-50 hover:text-[#1a2b6e] transition-colors">
                Catalysts <span class="arrow text-[#1a2b6e] opacity-0 -translate-x-1 transition-all font-bold text-base leading-none">›</span>
              </a>
            </div>
          </div>
        </div>

        <!-- Ecosystem -->
        <div class="relative h-full flex items-center" data-dropdown="ecosystem">
          <button data-trigger class="nav-link px-4 h-full flex items-center gap-1.5 text-white/85 hover:text-white transition-colors relative">
            Ecosystem
            <svg data-chevron class="w-3.5 h-3.5 text-white/40 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            <span class="nav-underline absolute bottom-0 left-0 w-full h-[3px] bg-[#cc1818] rounded-t scale-x-0 transition-transform origin-center duration-200"></span>
          </button>
          <div data-panel class="dropdown-panel absolute top-full left-0 w-72 pt-1 opacity-0 invisible translate-y-1 transition-all duration-200 pointer-events-none">
            <div class="bg-white border border-slate-100 shadow-2xl shadow-slate-200/60 rounded-xl py-2">
              <div class="relative" data-dropdown="capacity-dev">
                <button data-trigger class="dd-item w-full flex items-center justify-between px-5 py-2.5 text-slate-600 hover:bg-slate-50 hover:text-[#1a2b6e] transition-colors">
                  Capacity Development Programmes
                  <svg data-chevron class="w-3.5 h-3.5 text-slate-300 shrink-0 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                </button>
                <div data-panel class="dropdown-panel absolute top-0 left-full ml-1 w-80 opacity-0 invisible translate-x-[-4px] transition-all duration-200 pointer-events-none">
                  <div class="bg-white border border-slate-100 shadow-2xl shadow-slate-200/60 rounded-xl py-2">
                    <a href="#" class="dd-item block px-5 py-2.5 text-slate-600 hover:bg-slate-50 hover:text-[#1a2b6e] transition-colors">Faculty Development Programme</a>
                    <a href="#" class="dd-item block px-5 py-2.5 text-slate-600 hover:bg-slate-50 hover:text-[#1a2b6e] transition-colors">Entrepreneurship Awareness Camp</a>
                    <a href="#" class="dd-item block px-5 py-2.5 text-slate-600 hover:bg-slate-50 hover:text-[#1a2b6e] transition-colors leading-snug">Technology based Entrepreneurship<br><span class="text-xs text-slate-400 font-medium">Development Programme</span></a>
                    <a href="#" class="dd-item block px-5 py-2.5 text-slate-600 hover:bg-slate-50 hover:text-[#1a2b6e] transition-colors">Seminar / Workshop</a>
                    <a href="#" class="dd-item block px-5 py-2.5 text-slate-600 hover:bg-slate-50 hover:text-[#1a2b6e] transition-colors leading-snug">Leadership Course for<br><span class="text-xs text-slate-400 font-medium">Business Incubators</span></a>
                  </div>
                </div>
              </div>
              <div class="relative" data-dropdown="apin">
                <button data-trigger class="dd-item w-full flex items-center justify-between px-5 py-2.5 text-slate-600 hover:bg-slate-50 hover:text-[#1a2b6e] transition-colors">
                  Asia Pacific Incubation Network
                  <svg data-chevron class="w-3.5 h-3.5 text-slate-300 shrink-0 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                </button>
                <div data-panel class="dropdown-panel absolute top-0 left-full ml-1 w-80 opacity-0 invisible translate-x-[-4px] transition-all duration-200 pointer-events-none">
                  <div class="bg-white border border-slate-100 shadow-2xl shadow-slate-200/60 rounded-xl py-2">
                    <a href="#" class="dd-item block px-5 py-2.5 text-slate-600 hover:bg-slate-50 hover:text-[#1a2b6e] transition-colors leading-snug">International Training Programme on<br><span class="text-xs text-slate-400 font-medium">"Promoting Innovation and Entrepreneurship through Incubation"</span></a>
                    <a href="#" class="dd-item block px-5 py-2.5 text-slate-600 hover:bg-slate-50 hover:text-[#1a2b6e] transition-colors">Incubator Management Training</a>
                    <a href="#" class="dd-item block px-5 py-2.5 text-slate-600 hover:bg-slate-50 hover:text-[#1a2b6e] transition-colors">Intel DST Asia Pacific Challenge</a>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Media -->
        <div class="relative h-full flex items-center" data-dropdown="media">
          <button data-trigger class="nav-link px-4 h-full flex items-center gap-1.5 text-white/85 hover:text-white transition-colors relative">
            Media
            <svg data-chevron class="w-3.5 h-3.5 text-white/40 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            <span class="nav-underline absolute bottom-0 left-0 w-full h-[3px] bg-[#cc1818] rounded-t scale-x-0 transition-transform origin-center duration-200"></span>
          </button>
          <div data-panel class="dropdown-panel absolute top-full left-0 w-56 pt-1 opacity-0 invisible translate-y-1 transition-all duration-200 pointer-events-none">
            <div class="bg-white border border-slate-100 shadow-2xl shadow-slate-200/60 rounded-xl py-2">
              <a href="#" class="dd-item flex items-center justify-between px-5 py-2.5 text-slate-600 hover:bg-slate-50 hover:text-[#1a2b6e] transition-colors">
                Achievements <span class="arrow text-[#1a2b6e] opacity-0 -translate-x-1 transition-all font-bold text-base leading-none">›</span>
              </a>
              <a href="#" class="dd-item flex items-center justify-between px-5 py-2.5 text-slate-600 hover:bg-slate-50 hover:text-[#1a2b6e] transition-colors">
                News &amp; Events <span class="arrow text-[#1a2b6e] opacity-0 -translate-x-1 transition-all font-bold text-base leading-none">›</span>
              </a>
              <div class="relative" data-dropdown="press">
                <button data-trigger class="dd-item w-full flex items-center justify-between px-5 py-2.5 text-slate-600 hover:bg-slate-50 hover:text-[#1a2b6e] transition-colors">
                  Press Coverage
